@baseUrl = http://localhost:8080/api
@username = user
@email = user@example.com
@password = Password1!
@refreshToken = {{refreshToken}}
@accessToken = {{accessToken}}
@jobIdempotencyKey = 11111111-1111-4111-8111-111111111111

### Quota summary (requires Supabase user JWT from login)
GET {{baseUrl}}/quota/me
Authorization: Bearer {{accessToken}}

### Example: obtain a JWT via Supabase Auth (HTTP API through Kong)
# POST http://localhost:8000/auth/v1/token?grant_type=password
# Content-Type: application/json
# apikey: <ANON_KEY from docker/.env>
#
# { "email": "you@example.com", "password": "your-password" }
#
# Use access_token from the response as {{accessToken}} above.
{
  "username": "{{username}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
    const setCookie = response.headers.valueOf("set-cookie");
    if (setCookie) {
        const match = setCookie.match(/refresh_token=([^;]+)/);
        if (match) {
            client.global.set("refreshToken", match[1]);
        }
    }
    if (response.body.accessToken) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### Refresh token
POST {{baseUrl}}/auth/refresh
Cookie: refresh_token={{refreshToken}}

> {%
    if (response.body.accessToken) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### Logout
POST {{baseUrl}}/auth/logout
Cookie: refresh_token={{refreshToken}}

### Submit job with idempotency key
POST {{baseUrl}}/jobs
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Idempotency-Key: {{jobIdempotencyKey}}

{
  "dockerImage": "busybox",
  "executionCommand": "echo hello",
  "reqCpuCores": 1,
  "reqRamGb": 1,
  "envVars": {}
}

> {%
    if (response.body.jobId) {
        client.global.set("jobId", response.body.jobId);
    }
%}

### Replay same job submission with same idempotency key
POST {{baseUrl}}/jobs
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Idempotency-Key: {{jobIdempotencyKey}}

{
  "dockerImage": "alpine:latest",
  "executionCommand": "echo hello",
  "reqCpuCores": 1,
  "reqRamGb": 1,
  "envVars": {}
}

### Conflict: same idempotency key with different payload
POST {{baseUrl}}/jobs
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Idempotency-Key: {{jobIdempotencyKey}}

{
  "dockerImage": "alpine:latest",
  "executionCommand": "echo different",
  "reqCpuCores": 1,
  "reqRamGb": 1,
  "envVars": {}
}
