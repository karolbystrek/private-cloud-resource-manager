# Project Name
COMPOSE_PROJECT_NAME=pcrm

# --- Database  ---
POSTGRES_USER=pcrm_dev
POSTGRES_PASSWORD=pcrm_dev
POSTGRES_DB=pcrm_dev
POSTGRES_PORT=5432

# --- Broker  ---
BROKER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
DATABASE_URL=jdbc:postgresql://postgres:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_USERNAME=${POSTGRES_USER}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Redis  ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO  ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- HashiCorp Nomad ---
NOMAD_HTTP_PORT=4646
NOMAD_RPC_PORT=4647
NOMAD_SERF_PORT=4648

# --- Frontend ---
FRONTEND_PORT=3000
